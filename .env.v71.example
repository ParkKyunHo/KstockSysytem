# V7.1 .env template (Phase A 완료 + 후속 P-Wire-12/13/14 land 후)
# Phase: 운영 진입 Step 1.b (Claude가 V7.0 잔재 정리 + V7.1 placeholder 추가)
#
# Usage:
#   1. cp .env .env.v70.bak.YYYYMMDD              # 기존 백업
#   2. 본 파일을 참고해 .env 갱신 (시크릿 값은 직접 입력)
#   3. shared/.env (AWS) 동일 갱신 후 배포
#
# Security: 본 파일은 placeholder만, 실값은 절대 커밋 X (.gitignore 적용 확인).

# ============================================================
# § 1. 키움증권 API (필수)
# ============================================================
# Production keys (실거래)
KIWOOM_APP_KEY=                             # 43자 (앱 키)
KIWOOM_APP_SECRET=                          # 43자 (앱 시크릿)

# Paper / Sandbox keys (모의투자, 별도 발급)
KIWOOM_PAPER_APP_KEY=                       # 43자
KIWOOM_PAPER_APP_SECRET=                    # 43자

# Environment 분기 (V7.1 trading_bridge가 강제 검사)
#   PRODUCTION = 실거래 (KIWOOM_APP_*  사용)
#   SANDBOX    = 모의투자 (KIWOOM_PAPER_APP_* 사용)
# DEFAULT는 PRODUCTION -- 실수로 빈 값일 때 실거래로 fall through
# 시점에 운영 정책 확인 필수 (헌법 1).
KIWOOM_ENV=SANDBOX                          # PRODUCTION | SANDBOX

# 계좌번호 (kt00018 잔고 조회 + 주문 wire)
KIWOOM_ACCOUNT_NO=                          # 8~12자

# ============================================================
# § 2. 텔레그램 (필수)
# ============================================================
TELEGRAM_BOT_TOKEN=                         # 46자 (BotFather 발급)
TELEGRAM_CHAT_ID=                           # 9~11자 (chat ID, 음수면 그룹)

# ============================================================
# § 3. 데이터베이스 (필수, Supabase Pooler 권장)
# ============================================================
# 형식: postgresql://postgres.<project_ref>:<password>@aws-N-<region>.pooler.supabase.com:6543/postgres
# IPv6 직결 호스트는 Windows에서 비호환 -- Pooler URL 사용
DATABASE_URL=

# Supabase REST (선택, dashboard / RLS 통합 시)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=                   # anon key (Phase 5 dashboard 후속)
SUPABASE_SECRET_KEY=                        # service_role key (RLS bypass, 운영자만)

# ============================================================
# § 4. FastAPI 인증 (운영 필수)
# ============================================================
# 32+ chars random hex (e.g. `python -c "import secrets; print(secrets.token_hex(32))"`)
JWT_SECRET=

# ============================================================
# § 5. V7.1 운영 옵션
# ============================================================
# Trading engine boot
V71_WEB_BOOT_TRADING_ENGINE=true            # FastAPI 부팅 시 trading_engine attach
V71_AUTO_TRADING=false                      # 자동 매매 활성화 (실거래 시작)

# Reconciler interval override (default 300s)
# V71_RECONCILER_INTERVAL_SECONDS=300

# ============================================================
# § 6. 로깅 / 환경
# ============================================================
ENVIRONMENT=production                      # development | staging | production
LOG_LEVEL=INFO                              # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                             # json | text

# ============================================================
# § 7. (Phase 6 후순위) Anthropic LLM 리포트
# ============================================================
# ANTHROPIC_API_KEY=

# ============================================================
# § 8. V7.0 잔재 (제거 대상, V7.1 코드 무관)
# ============================================================
# 다음 변수는 V7.1에서 읽지 않습니다. 정리 권장:
#   ATR_ALERT_ENABLED, ATR_TRAILING_*, ATR_ALERT_*
#   AUTO_UNIVERSE_*
#   SNIPER_TRAP_ENABLED
#   TS_ATR_*
#   VI_COOLDOWN_SECONDS, VI_TIMEOUT_SECONDS
#   WATCHLIST_*
#   EMA_STRUCT_LEN, USE_HL_BREAK, USE_VWAP_WARN
#   BREAKEVEN_*, BUY_AMOUNT_RATIO, BUY_COOLDOWN_SECONDS
#   CANDLE_HISTORY_COUNT, CANDLE_LOAD_*
#   CONFIRM_BARS, CONDITION_SEQS
#   EOD_ALERT_TIME, EOD_DEFAULT_ACTION
#   GLOBAL_LOCK_*, MAX_HOLDING_DAYS, MAX_POSITIONS, MAX_*, MIN_*
#   PARTIAL_*, POSITION_SYNC_INTERVAL
#   SAFETY_*, SIGNAL_START_TIME
#   IS_PAPER_TRADING       (V7.1은 KIWOOM_ENV로 대체)
#   TRADING_MODE
#   USE_PARTIAL_EXIT, WAIT_FOR_MARKET_OPEN
#   PARALLEL_CANDLE_LOADING
#   AUTO_UNIVERSE_CONDITION_SEQ
