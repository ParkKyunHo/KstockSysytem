# =========================================
# K_stock_trading 환경 변수 설정
# =========================================
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요.
# 절대로 .env 파일을 git에 커밋하지 마세요!
# =========================================

# 투자 환경 (true: 모의투자, false: 실전투자)
IS_PAPER_TRADING=false

# =========================================
# 키움증권 API 설정
# =========================================
# 실전투자용
KIWOOM_APP_KEY=your_real_app_key_here
KIWOOM_APP_SECRET=your_real_app_secret_here

# 모의투자용 (선택)
KIWOOM_PAPER_APP_KEY=your_paper_app_key_here
KIWOOM_PAPER_APP_SECRET=your_paper_app_secret_here

# =========================================
# 텔레그램 봇 설정
# =========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# =========================================
# 데이터베이스 설정
# =========================================
# Supabase (권장) - Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:***LEAKED-PW-REDACTED***@db.wlkcuqfflmdshpzbfndz.supabase.co:5432/postgres

# PostgreSQL (AWS RDS 또는 로컬)
# DATABASE_URL=postgresql://user:password@localhost:5432/k_stock_trading

# SQLite (로컬 개발, DB 미설정 시 자동 폴백)
# DATABASE_URL 주석 처리 시 data/k_stock_trading.db 파일 사용

# =========================================
# 리스크 관리 설정
# =========================================
# 일일 최대 손실액 (원)
DAILY_MAX_LOSS=100000

# PRD v2.0: 백업 손절 기준 (%)
# 일반 손절(-10%)과 별개로 -5% 도달 시 강제 청산
BACKUP_STOP_LOSS_RATE=-5.0

# 최대 보유 종목 수
MAX_POSITIONS=10

# 종목당 매수 비율 (%)
BUY_RATIO=3.0

# 익절 기준 (%)
TAKE_PROFIT_RATE=5.0

# 손절 기준 (%)
STOP_LOSS_RATE=-10.0

# =========================================
# 전략 설정
# =========================================
# 모니터링할 조건식 번호 (쉼표로 구분)
CONDITION_SEQS=0,1

# 장 종료 알림 시간 (HH:MM)
EOD_ALERT_TIME=15:15

# 응답 없을 시 기본 동작 (hold/liquidate)
EOD_DEFAULT_ACTION=hold

# =========================================
# 로깅 설정
# =========================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =========================================
# 운영 환경 설정
# =========================================
# development, staging, production
ENVIRONMENT=development
