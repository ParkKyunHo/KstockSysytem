# V7.1 environment variables — keys only, no secrets.
# Copy to .env and fill in for production. Local dev uses
# scripts/dev_run_local.py which forces V71_WEB_ENVIRONMENT=dev and
# strips PostgreSQL vars below before importing settings (no secrets
# needed for dev — SQLite + seeded user 'admin'/'admin').

# ---------------------------------------------------------------------
# Mode
# ---------------------------------------------------------------------
V71_WEB_ENVIRONMENT=prod          # dev | staging | prod
V71_WEB_DEBUG=false
V71_WEB_BOOT_TRADING_ENGINE=true  # MUST be false for dev

# ---------------------------------------------------------------------
# Auth (JWT)
# ---------------------------------------------------------------------
JWT_SECRET=                       # 64+ char random hex (production only)
V71_WEB_ACCESS_TOKEN_MINUTES=30
V71_WEB_REFRESH_TOKEN_HOURS=24

# ---------------------------------------------------------------------
# Database (production only — dev launcher routes at SQLite data/dev.db)
# ---------------------------------------------------------------------
DATABASE_URL=                     # Supabase Pooler URL, e.g. postgresql://postgres.<ref>:<pwd>@aws-N-<region>.pooler.supabase.com:6543/postgres?sslmode=require
SQLITE_PATH=data/k_stock_trading.db

# ---------------------------------------------------------------------
# Kiwoom REST API (production only — never called in dev)
# ---------------------------------------------------------------------
KIWOOM_ENV=PRODUCTION             # PRODUCTION | SANDBOX
KIWOOM_APP_KEY=
KIWOOM_APP_SECRET=
KIWOOM_ACCOUNT_NO=
KIWOOM_PAPER_APP_KEY=
KIWOOM_PAPER_APP_SECRET=

# ---------------------------------------------------------------------
# Telegram bot
# ---------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# ---------------------------------------------------------------------
# CORS (defaults already include http://localhost:5173 for vite dev)
# ---------------------------------------------------------------------
# V71_WEB_CORS_ORIGINS=["https://albra.net"]
